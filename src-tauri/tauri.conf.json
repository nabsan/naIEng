{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "naIEng",
  "version": "0.1.0",
  "identifier": "com.codex.naieng",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "English Flight Deck",
        "width": 1360,
        "height": 920,
        "minWidth": 1040,
        "minHeight": 760,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
